---
import MainHead from '../components/MainHead.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const { title, description } = Astro.props;

const navLinks = [
	{ label: 'Index', href: '#top' },
	{ label: 'Projects', href: '#projects' },
	{ label: 'About', href: '#about' },
	{ label: 'Contact', href: '#contact' },
];

const year = new Date().getFullYear();
---

<html lang="en">
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<!-- CRT scanline + vignette overlay -->
		<div class="crt" aria-hidden="true"></div>

		<header class="topbar">
			<a class="brand" href="#top">
				<span class="prompt">&gt;</span> N.GARZIONE
			</a>
			<nav class="nav" aria-label="Primary">
				{navLinks.map(({ label, href }) => <a href={href}>{label}</a>)}
			</nav>
		</header>

		<main id="top">
			<slot />
		</main>

		<footer class="statusline">
			<div class="wrapper statusline-inner">
				<span>&copy; {year} NICOLAS GARZIONE</span>
				<span class="muted">SYS: ONLINE // BUILT WITH ASTRO</span>
			</div>
		</footer>

		<style>
			.crt {
				position: fixed;
				inset: 0;
				z-index: 9998;
				pointer-events: none;
				/* horizontal scanlines */
				background: repeating-linear-gradient(
					to bottom,
					rgba(0, 0, 0, 0) 0,
					rgba(0, 0, 0, 0) 2px,
					rgba(0, 0, 0, 0.18) 3px,
					rgba(0, 0, 0, 0.18) 3px
				);
				mix-blend-mode: multiply;
			}
			.crt::after {
				/* corner vignette */
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(
					ellipse at center,
					transparent 55%,
					rgba(0, 0, 0, 0.55) 100%
				);
			}

			.topbar {
				position: sticky;
				top: 0;
				z-index: 100;
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
				padding: 0.75rem var(--gutter);
				background: rgba(10, 10, 8, 0.92);
				border-bottom: 1px solid var(--line);
				backdrop-filter: blur(4px);
			}
			.brand {
				font-weight: 800;
				letter-spacing: 0.18em;
				color: var(--amber);
			}
			.brand:hover {
				text-decoration: none;
			}
			.prompt {
				color: var(--red);
			}
			.nav {
				display: flex;
				gap: 1.1rem;
				flex-wrap: wrap;
				font-size: var(--text-sm);
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}
			.nav a {
				color: var(--fg-dim);
			}
			.nav a:hover {
				color: var(--amber);
				text-decoration: none;
			}

			.statusline {
				margin-top: 4rem;
				border-top: 1px solid var(--line);
				background: var(--bg-panel);
				font-size: var(--text-xs);
				letter-spacing: 0.1em;
				text-transform: uppercase;
				color: var(--fg-dim);
			}
			.statusline-inner {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				flex-wrap: wrap;
				padding-block: 1rem;
			}
			.muted {
				color: var(--amber-dim);
			}
		</style>
	</body>
</html>
